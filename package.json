  "license": "ISC",
  "keywords": [],
  "description": "",
  "dependencies": {
    "@google/genai": "^2.12.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.12.0",
    "mongoose": "^9.7.4",
    "multer": "^2.2.0",
    "p-retry": "^7.1.1",
    "pdf-parse": "^1.1.1",
    "razorpay": "^2.9.6",
    "react-bootstrap-icons": "^1.11.6",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
