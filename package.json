{
  "name": "servicehub",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:server": "nodemon server.js",
    "dev:client": "npm run dev --prefix frontend",
    "dev:all": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"wait-on http://127.0.0.1:8080 -t 30000 && npm run dev:client\"",
    "install:all": "npm install && npm install --prefix frontend",
    "build:client": "npm run build --prefix frontend"
  },
